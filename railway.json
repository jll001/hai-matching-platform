{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node index.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "healthcheckInterval": 1000,
    "healthcheckRetries": 3
  }
}
